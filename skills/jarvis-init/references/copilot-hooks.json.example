{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash $SKILLS_DIR/jarvis-reload/scripts/jarvis-session-start-copilot.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "bash $SKILLS_DIR/jarvis-reflect/scripts/jarvis-session-end-copilot.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
